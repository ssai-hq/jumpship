# These are conspicuously synthetic local-fixture credentials. Never reuse them
# for a shared environment, customer system, or cloud account.
JUMPSHIP_FIXTURE_POSTGRES_USER=jumpship_fixture
JUMPSHIP_FIXTURE_POSTGRES_PASSWORD=jumpship_fixture_not_a_secret
JUMPSHIP_FIXTURE_MONGO_USER=jumpship_fixture
JUMPSHIP_FIXTURE_MONGO_PASSWORD=jumpship_fixture_not_a_secret
JUMPSHIP_FIXTURE_MONGO_KEY=obviouslySyntheticLocalReplicaKeyNotASecret123456789
JUMPSHIP_FIXTURE_MINIO_USER=jumpship_fixture
JUMPSHIP_FIXTURE_MINIO_PASSWORD=jumpship_fixture_not_a_secret

# All published ports bind to 127.0.0.1. Override only to resolve a local port
# collision; the Compose file does not permit overriding the bind address.
JUMPSHIP_CONTROL_POSTGRES_PORT=15432
JUMPSHIP_CELL_POSTGRES_PORT=15433
JUMPSHIP_TARGET_POSTGRES_PORT=15435
JUMPSHIP_MONGO_PORT=27017
JUMPSHIP_MINIO_API_PORT=19000
JUMPSHIP_MINIO_CONSOLE_PORT=19001
JUMPSHIP_MAILPIT_SMTP_PORT=11025
JUMPSHIP_MAILPIT_UI_PORT=18025
