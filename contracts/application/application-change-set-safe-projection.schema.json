{
  "$id": "https://jumpship.dev/contracts/application/application-change-set-safe-projection.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Browser/API projection containing aggregate status only; repositories, refs, file paths, diffs, validation output, and customer content remain cell-local.",
  "properties": {
    "blocker_count": {
      "maximum": 100000,
      "minimum": 0,
      "type": "integer"
    },
    "change_set_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "customer_validation_current": {
      "type": "boolean"
    },
    "degraded_validation_count": {
      "maximum": 4096,
      "minimum": 0,
      "type": "integer"
    },
    "migration_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "patch_set_count": {
      "maximum": 4096,
      "minimum": 0,
      "type": "integer"
    },
    "projection_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "repository_count": {
      "maximum": 4096,
      "minimum": 0,
      "type": "integer"
    },
    "safe_summary": {
      "maxLength": 2048,
      "minLength": 1,
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "state": {
      "enum": [
        "planned",
        "generating",
        "validating",
        "blocked",
        "publishable",
        "published",
        "superseded",
        "failed"
      ],
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
      "type": "string"
    },
    "validated_patch_set_count": {
      "maximum": 4096,
      "minimum": 0,
      "type": "integer"
    },
    "version": {
      "minimum": 1,
      "type": "integer"
    },
    "workspace_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "change_set_id",
    "workspace_id",
    "migration_id",
    "version",
    "state",
    "repository_count",
    "patch_set_count",
    "validated_patch_set_count",
    "degraded_validation_count",
    "blocker_count",
    "customer_validation_current",
    "safe_summary",
    "projection_root",
    "updated_at"
  ],
  "title": "Jumpship Shared-Safe Application Change Set Projection Contract",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "shared_migration",
  "x-jumpship-flow-ids": [
    "F02",
    "F03",
    "F11"
  ],
  "x-jumpship-max-bytes": 65536
}
