          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "redacted_export_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "source_high_watermark": {
      "maxLength": 256,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "checkpoint_id",
    "previous_checkpoint_hash",
    "export_request_id",
    "interval_started_at",
    "interval_ended_at",
    "event_count",
    "redacted_export_root",
