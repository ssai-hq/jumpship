{
  "$id": "https://jumpship.dev/contracts/audit/checkpoint.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Canonical unsigned audit-checkpoint candidate. Only the offline audit root may attach a detached purpose=audit_checkpoint SignatureEnvelope.",
  "properties": {
    "checkpoint_id": {
