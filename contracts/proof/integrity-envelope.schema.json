{
  "$id": "https://jumpship.dev/contracts/proof/integrity-envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Detached purpose-specific signed migration integrity proof with all schema and evidence roots.",
  "properties": {
    "both_direction_set_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "cell_generation": {
      "minimum": 1,
      "type": "integer"
    },
    "cell_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "evidence_index_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "integrity_envelope_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "issued_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
      "type": "string"
    },
    "logical_payload_projection": {
      "additionalProperties": false,
      "properties": {
        "canonical_encoder": {
          "const": "RFC8785_JCS",
          "type": "string"
        },
        "domain_separator": {
          "const": "jumpship:integrity_envelope:1.0.0\u0000",
          "type": "string"
        },
        "excluded_fields": {
          "const": [
            "integrity_envelope_id",
            "content_sha256",
            "logical_payload_sha256",
            "logical_payload_projection",
            "signature_envelope_hash"
          ],
          "maxItems": 5,
          "minItems": 5,
          "type": "array"
        },
        "id_encoding": {
          "const": "lowercase_hex_sha256",
          "type": "string"
        },
        "id_equals_logical_payload_sha256": {
          "const": true,
          "type": "boolean"
        },
        "id_field": {
          "const": "integrity_envelope_id",
          "type": "string"
        },
        "object_schema_version": {
          "const": "1.0.0",
          "type": "string"
        },
        "object_type": {
          "const": "integrity_envelope",
          "type": "string"
        }
      },
      "required": [
        "object_type",
        "id_field",
        "object_schema_version",
        "canonical_encoder",
        "domain_separator",
        "excluded_fields",
        "id_encoding",
        "id_equals_logical_payload_sha256"
      ],
      "type": "object"
    },
    "logical_payload_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "mapping_spec_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "migration_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "proof_version": {
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "public_key_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "query_semantic_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "signature_envelope_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "signature_purpose": {
      "const": "migration_integrity_proof",
      "type": "string"
    },
    "source_manifest_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "target_manifest_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "verification_rubric_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "workspace_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "integrity_envelope_id",
    "workspace_id",
    "migration_id",
    "cell_id",
    "cell_generation",
    "proof_version",
    "mapping_spec_hash",
    "verification_rubric_hash",
    "source_manifest_root",
    "target_manifest_root",
    "both_direction_set_root",
    "query_semantic_root",
    "evidence_index_root",
    "public_key_fingerprint",
    "signature_purpose",
    "signature_envelope_hash",
    "issued_at",
    "logical_payload_sha256",
    "logical_payload_projection"
  ],
  "title": "Migration Integrity Envelope Contract",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "security_material",
  "x-jumpship-flow-ids": [
    "F20",
    "F24"
  ],
  "x-jumpship-max-bytes": 524288
}
