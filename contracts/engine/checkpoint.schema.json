{
  "$id": "https://jumpship.dev/contracts/engine/checkpoint.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Cell-local deterministic engine checkpoint. Only hashes and separately sanitized safe summaries may cross to the shared plane.",
  "properties": {
    "artifact_roots": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "maxItems": 128,
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "attempt_id": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "causation_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "cell_generation": {
      "minimum": 1,
      "type": "integer"
    },
    "cell_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "cell_write_epoch": {
      "minimum": 0,
      "type": "integer"
    },
    "checkpoint_schema_version": {
      "maxLength": 64,
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "checkpoint_sequence": {
      "minimum": 1,
      "type": "integer"
    },
    "correlation_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
      "type": "string"
    },
    "cursors": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "maxLength": 128,
            "pattern": "^[a-z][a-z0-9_.-]{0,127}$",
            "type": "string"
          },
          "position_hash": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "sequence": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "name",
          "position_hash",
          "sequence"
        ],
        "type": "object"
      },
      "maxItems": 64,
      "minItems": 0,
      "type": "array"
    },
    "engine_checkpoint_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "engine_version": {
      "maxLength": 64,
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "migration_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "operation_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "plan_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "previous_checkpoint_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "status": {
      "enum": [
        "active",
        "waiting",
        "terminal"
      ],
      "type": "string"
    },
    "workspace_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "workspace_id",
    "migration_id",
    "cell_id",
    "cell_generation",
    "causation_id",
    "correlation_id",
    "operation_id",
    "engine_checkpoint_id",
    "previous_checkpoint_hash",
    "attempt_id",
    "checkpoint_schema_version",
    "engine_version",
    "plan_hash",
    "cell_write_epoch",
    "checkpoint_sequence",
    "status",
    "cursors",
    "artifact_roots",
    "created_at"
  ],
  "title": "Engine Checkpoint",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "restricted_customer",
  "x-jumpship-flow-ids": [
    "F13"
  ],
  "x-jumpship-max-bytes": 262144
}
