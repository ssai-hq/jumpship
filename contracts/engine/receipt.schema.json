{
  "$id": "https://jumpship.dev/contracts/engine/receipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Append-only terminal engine receipt with safe reason/summary and content roots; raw tool/provider output remains cell-local.",
  "properties": {
    "after_root_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "attempt_id": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "before_root_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "causation_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "cell_generation": {
      "minimum": 1,
      "type": "integer"
    },
    "cell_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "checkpoint_id": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "consequence_class": {
      "enum": [
        "observation",
        "deterministic_effect",
        "irreversible_boundary"
      ],
      "type": "string"
    },
    "correlation_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "engine_receipt_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "finished_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
      "type": "string"
    },
    "idempotency_key_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "migration_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "operation_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "outcome": {
      "enum": [
        "succeeded",
        "failed_retryable",
        "failed_terminal",
        "denied"
      ],
      "type": "string"
    },
    "provider_receipt_roots": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "maxItems": 64,
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "safe_reason_code": {
      "anyOf": [
        {
          "maxLength": 96,
          "pattern": "^[a-z][a-z0-9_.-]{0,95}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "safe_summary": {
      "maxLength": 2048,
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "started_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
      "type": "string"
    },
    "tool_descriptor_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "workspace_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "workspace_id",
    "migration_id",
    "cell_id",
    "cell_generation",
    "causation_id",
    "correlation_id",
    "operation_id",
    "engine_receipt_id",
    "attempt_id",
    "checkpoint_id",
    "tool_descriptor_hash",
    "consequence_class",
    "outcome",
    "before_root_hash",
    "after_root_hash",
    "provider_receipt_roots",
    "idempotency_key_hash",
    "safe_reason_code",
    "safe_summary",
    "started_at",
    "finished_at"
  ],
  "title": "Engine Receipt",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "shared_migration",
  "x-jumpship-flow-ids": [
    "F03",
    "F06",
    "F10",
    "F17"
  ],
  "x-jumpship-max-bytes": 65536
}
