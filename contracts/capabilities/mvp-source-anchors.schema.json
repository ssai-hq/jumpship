{
  "$id": "https://jumpship.dev/schemas/capabilities/mvp-source-anchors.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "anchor_algorithm": { "type": "string", "const": "jumpship-capability-anchors-v1" },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["anchor_id", "content_sha256", "kind", "source_line", "title"],
        "properties": {
          "anchor_id": {
            "type": "string",
            "pattern": "^(?:numbered-list:[0-9]+[a-z]?:[a-z0-9]+(?:-[a-z0-9]+)*|addendum:[a-z0-9][a-z0-9-]*[a-z0-9])$"
          },
          "content_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "display": { "type": "string", "pattern": "^[0-9]+[a-z]?$" },
          "heading_level": { "type": "integer" },
          "heading_path": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" }
          },
          "kind": { "type": "string", "enum": ["numbered-list", "addendum"] },
          "occurrence": { "type": "integer" },
          "occurrence_count": { "type": "integer" },
          "source_line": { "type": "integer" },
          "title": { "type": "string", "minLength": 1 }
        }
      }
    },
    "logical_source_version": { "type": "string", "minLength": 1 },
    "planning_inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "source_plan_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "required": [
    "$schema",
    "anchor_algorithm",
    "anchors",
    "logical_source_version",
    "planning_inputs",
    "schema_version",
    "source",
    "source_plan_sha256"
  ],
  "title": "Jumpship accepted living-source anchor manifest",
  "type": "object"
}
