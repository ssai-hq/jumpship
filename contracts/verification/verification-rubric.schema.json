{
  "$id": "https://jumpship.dev/contracts/verification/verification-rubric.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Immutable pre-registered verification expectations; customer values are forbidden.",
  "properties": {
    "checks": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "blocking": {
            "type": "boolean"
          },
          "check_id": {
            "maxLength": 128,
            "pattern": "^[a-z][a-z0-9_.-]{0,127}$",
            "type": "string"
          },
          "evidence_roots": {
            "items": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "maxItems": 16,
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "expectation_kind": {
            "enum": [
              "exact_hash",
              "exact_count",
              "boolean",
              "bounded_numeric",
              "zero_unexplained"
            ],
            "type": "string"
          },
          "expected_count": {
            "anyOf": [
              {
                "minimum": 0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ]
          },
          "expected_hash": {
            "anyOf": [
              {
                "pattern": "^[0-9a-f]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "layer": {
            "enum": [
              "counts",
              "business_invariants",
              "canonical_hash",
              "reverse_difference",
              "query_semantics"
            ],
            "type": "string"
          },
          "maximum": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "minimum": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "check_id",
          "layer",
          "expectation_kind",
          "expected_hash",
          "expected_count",
          "minimum",
          "maximum",
          "blocking",
          "evidence_roots"
        ],
        "type": "object"
      },
      "maxItems": 1024,
      "minItems": 1,
      "type": "array"
    },
    "confirmed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "confirmed_by": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "mapping_spec_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "mapping_spec_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "status": {
      "enum": [
        "draft",
        "confirmed",
        "superseded"
      ],
      "type": "string"
    },
    "verification_rubric_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "version": {
      "minimum": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "verification_rubric_id",
    "version",
    "status",
    "mapping_spec_id",
    "mapping_spec_hash",
    "confirmed_by",
    "confirmed_at",
    "checks"
  ],
  "title": "Verification Rubric",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "shared_migration",
  "x-jumpship-flow-ids": [
    "F02",
    "F03",
    "F06"
  ],
  "x-jumpship-max-bytes": 1048576
}
