{
  "$id": "https://jumpship.dev/contracts/quality/eval-case.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Immutable reviewed evaluation case; expectation changes require a new version.",
  "properties": {
    "authority_denials": {
      "items": {
        "maxLength": 256,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 64,
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "case_kind": {
      "enum": [
        "deterministic",
        "trajectory",
        "security",
        "application_adaptation",
        "writer_cutover"
      ],
      "type": "string"
    },
    "case_version": {
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "eval_case_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "expectation_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "expectation_schema_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "input_fixture_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "required_checker_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 64,
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "required_grader_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 32,
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "review_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_version",
    "eval_case_id",
    "case_version",
    "case_kind",
    "input_fixture_hash",
    "expectation_schema_hash",
    "expectation_hash",
    "required_checker_ids",
    "required_grader_ids",
    "authority_denials",
    "review_root"
  ],
  "title": "Agent Evaluation Case Contract",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "internal_operational",
  "x-jumpship-flow-ids": [
    "F22",
    "F24"
  ],
  "x-jumpship-max-bytes": 262144
}
