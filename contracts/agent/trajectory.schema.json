{
  "$id": "https://jumpship.dev/contracts/agent/trajectory.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Allowlisted trajectory projection for evaluation; raw evidence and chain-of-thought are excluded.",
  "properties": {
    "bundle_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "contains_raw_evidence": {
      "const": false,
      "type": "boolean"
    },
    "events": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "context_manifest_hash": {
            "anyOf": [
              {
                "pattern": "^[0-9a-f]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "event_kind": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string"
          },
          "event_root": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "occurred_at": {
            "format": "date-time",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
            "type": "string"
          },
          "safe_summary": {
            "maxLength": 1024,
            "minLength": 1,
            "type": "string"
          },
          "sequence": {
            "minimum": 1,
            "type": "integer"
          },
          "tool_receipt_hash": {
            "anyOf": [
              {
                "pattern": "^[0-9a-f]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "sequence",
          "event_kind",
          "occurred_at",
          "safe_summary",
          "event_root",
          "context_manifest_hash",
          "tool_receipt_hash"
        ],
        "type": "object"
      },
      "maxItems": 4096,
      "minItems": 1,
      "type": "array"
    },
    "postures_observed": {
      "items": {
        "enum": [
          "design",
          "migration_ops"
        ],
        "type": "string"
      },
      "maxItems": 2,
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "run_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "sanitizer_policy_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "sanitizer_version": {
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "trajectory_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "trajectory_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "trajectory_id",
    "bundle_id",
    "run_id",
    "postures_observed",
    "events",
    "sanitizer_version",
    "sanitizer_policy_hash",
    "trajectory_root",
    "contains_raw_evidence"
  ],
  "title": "Sanitized Agent Trajectory Export Contract",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "internal_operational",
  "x-jumpship-flow-ids": [
    "F22",
    "F24"
  ],
  "x-jumpship-max-bytes": 4194304
}
