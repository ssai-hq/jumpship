{
  "$id": "https://jumpship.dev/contracts/agent/runtime.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Framework-neutral runtime and bounded durable-loop compatibility contract.",
  "properties": {
    "adapter_kind": {
      "enum": [
        "custom_reference_loop",
        "conformance_adapter"
      ],
      "type": "string"
    },
    "binary_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "checkpoint_schema_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "execution_contract": {
      "additionalProperties": false,
      "properties": {
        "durable_before_consequence": {
          "const": true,
          "type": "boolean"
        },
        "model_driven_cdc_or_watch": {
          "const": false,
          "type": "boolean"
        },
        "parallel_observations_allowed": {
          "const": false,
          "type": "boolean"
        },
        "sequential_inline_observations": {
          "const": true,
          "type": "boolean"
        },
        "single_active_lease": {
          "const": true,
          "type": "boolean"
        }
      },
      "required": [
        "single_active_lease",
        "sequential_inline_observations",
        "parallel_observations_allowed",
        "durable_before_consequence",
        "model_driven_cdc_or_watch"
      ],
      "type": "object"
    },
    "max_model_iterations_per_run": {
      "maximum": 64,
      "minimum": 1,
      "type": "integer"
    },
    "max_run_seconds": {
      "maximum": 86400,
      "minimum": 1,
      "type": "integer"
    },
    "runtime_id": {
      "maxLength": 128,
      "minLength": 1,
      "type": "string"
    },
    "runtime_version": {
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "supported_checkpoint_versions": {
      "items": {
        "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$",
        "type": "string"
      },
      "maxItems": 16,
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "schema_version",
    "runtime_id",
    "runtime_version",
    "adapter_kind",
    "checkpoint_schema_hash",
    "supported_checkpoint_versions",
    "max_model_iterations_per_run",
    "max_run_seconds",
    "execution_contract",
    "binary_sha256"
  ],
  "title": "Agent Runtime Contract",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "internal_operational",
  "x-jumpship-flow-ids": [
    "F17",
    "F22"
  ],
  "x-jumpship-max-bytes": 32768
}
