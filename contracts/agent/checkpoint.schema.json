{
  "$id": "https://jumpship.dev/contracts/agent/checkpoint.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Per-completed-iteration durable checkpoint using the existing run/event/checkpoint timeline.",
  "properties": {
    "budget": {
      "additionalProperties": false,
      "properties": {
        "elapsed_limit_seconds": {
          "maximum": 86400,
          "minimum": 1,
          "type": "integer"
        },
        "elapsed_seconds": {
          "maximum": 86400,
          "minimum": 0,
          "type": "integer"
        },
        "model_calls_limit": {
          "maximum": 64,
          "minimum": 1,
          "type": "integer"
        },
        "model_calls_used": {
          "maximum": 64,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "model_calls_used",
        "model_calls_limit",
        "elapsed_seconds",
        "elapsed_limit_seconds"
      ],
      "type": "object"
    },
    "checkpoint_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "checkpoint_version": {
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$",
      "type": "string"
    },
    "context_manifest_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "context_manifest_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
      "type": "string"
    },
    "event_root": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "iteration_sequence": {
      "minimum": 1,
      "type": "integer"
    },
    "lease_epoch": {
      "minimum": 1,
      "type": "integer"
    },
    "lease_expires_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
      "type": "string"
    },
    "pending_outcome": {
      "enum": [
        "continue",
        "wait",
        "decision",
        "effect_request",
        "complete",
        "failed"
      ],
      "type": "string"
    },
    "prior_checkpoint_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "run_id": {
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "steering_sequence": {
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "checkpoint_id",
    "checkpoint_version",
    "run_id",
    "iteration_sequence",
    "lease_epoch",
    "lease_expires_at",
    "event_root",
    "prior_checkpoint_hash",
    "context_manifest_id",
    "context_manifest_hash",
    "pending_outcome",
    "steering_sequence",
    "budget",
    "created_at"
  ],
  "title": "Agent Durable Checkpoint Contract",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "restricted_customer",
  "x-jumpship-flow-ids": [
    "F17"
  ],
  "x-jumpship-max-bytes": 262144
}
