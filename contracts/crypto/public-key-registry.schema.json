{
  "$id": "https://jumpship.dev/contracts/crypto/public-key-registry.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "else": {
        "properties": {
          "previous_registry_hash": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          }
        }
      },
      "if": {
        "properties": {
          "registry_version": {
            "const": 1
          }
        },
        "required": [
          "registry_version"
        ]
      },
      "then": {
        "properties": {
          "previous_registry_hash": {
            "type": "null"
          }
        }
      }
    }
  ],
  "description": "Monotonic purpose/environment/tenant-scoped public-key registry. It contains no private material and is the sole Jumpship trust-bundle input to offline verification.",
  "properties": {
    "issued_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
      "type": "string"
    },
    "keys": {
      "items": {
        "additionalProperties": false,
        "allOf": [
          {
            "else": {
              "properties": {
                "revocation_reason": {
                  "type": "null"
                },
                "revoked_at": {
                  "type": "null"
                }
              }
            },
            "if": {
              "properties": {
                "status": {
                  "const": "revoked"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "revocation_reason": {
                  "maxLength": 96,
                  "pattern": "^[a-z][a-z0-9_.-]{0,95}$",
                  "type": "string"
                },
                "revoked_at": {
                  "format": "date-time",
                  "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
                  "type": "string"
                }
              }
            }
          }
        ],
        "properties": {
          "algorithm": {
            "enum": [
              "ECDSA_P256_SHA256",
              "RSA_PSS_SHA256"
            ],
            "type": "string"
          },
          "environments": {
            "items": {
              "enum": [
                "local",
                "ephemeral-nonprod",
                "persistent-nonprod",
                "isolated-quality",
                "staging",
                "production"
              ],
              "type": "string"
            },
            "maxItems": 6,
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "kid": {
            "maxLength": 128,
            "pattern": "^[a-z][a-z0-9_.-]{0,127}$",
            "type": "string"
          },
          "public_key_pem": {
            "maxLength": 8192,
            "minLength": 128,
            "pattern": "^-----BEGIN PUBLIC KEY-----[A-Za-z0-9+/=\\r\\n-]+-----END PUBLIC KEY-----$",
            "type": "string"
          },
          "purposes": {
            "items": {
              "maxLength": 128,
              "pattern": "^[a-z][a-z0-9_.-]{0,127}$",
              "type": "string"
            },
            "maxItems": 32,
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "revocation_reason": {
            "anyOf": [
              {
                "maxLength": 96,
                "pattern": "^[a-z][a-z0-9_.-]{0,95}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "revoked_at": {
            "anyOf": [
              {
                "format": "date-time",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "status": {
            "enum": [
              "active",
              "superseded",
              "revoked"
            ],
            "type": "string"
          },
          "supersedes_kid": {
            "anyOf": [
              {
                "maxLength": 128,
                "pattern": "^[a-z][a-z0-9_.-]{0,127}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "tenant_scope": {
            "anyOf": [
              {
                "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "valid_from": {
            "format": "date-time",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
            "type": "string"
          },
          "valid_until": {
            "format": "date-time",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$",
            "type": "string"
          }
        },
        "required": [
          "kid",
          "algorithm",
          "public_key_pem",
          "purposes",
          "environments",
          "tenant_scope",
          "valid_from",
          "valid_until",
          "status",
          "supersedes_kid",
          "revoked_at",
          "revocation_reason"
        ],
        "type": "object"
      },
      "maxItems": 256,
      "minItems": 1,
      "type": "array"
    },
    "previous_registry_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "purpose_policy_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "registry_id": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "registry_version": {
      "minimum": 1,
      "type": "integer"
    },
    "root_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_version",
    "registry_id",
    "registry_version",
    "previous_registry_hash",
    "root_fingerprint",
    "purpose_policy_hash",
    "issued_at",
    "keys"
  ],
  "title": "Public Key Registry",
  "type": "object",
  "x-generated-by": "internal/contracts/codegen/generate.py",
  "x-jumpship-compatibility": "additive-with-versioned-breaking-change",
  "x-jumpship-data-class": "public",
  "x-jumpship-flow-ids": [
    "F06",
    "F17"
  ],
  "x-jumpship-max-bytes": 1048576
}
